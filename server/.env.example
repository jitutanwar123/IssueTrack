# Server Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=viraj_ticketing
PORT=5000

# ─── JWT ──────────────────────────────────────────────────────────
# Generate a strong random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Gmail Email (Nodemailer) ─────────────────────────────────────
# 1. Go to your Google Account → Security → 2-Step Verification (enable it)
# 2. Then go to: Security → App passwords
# 3. Create an app password for "Mail" → "Other (Custom name)" → name it "VirajTicketing"
# 4. Copy the 16-character password (no spaces) into GMAIL_APP_PASSWORD below
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ─── Admin notification email ─────────────────────────────────────
# This email receives notifications when users create tickets or add replies
ADMIN_EMAIL=admin@virajprofiles.com
