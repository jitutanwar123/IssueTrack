# Server Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=viraj_ticketing
PORT=5000

# ─── JWT ──────────────────────────────────────────────────────────
# Generate a strong random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Brevo Email ──────────────────────────────────────────────────
# Use a verified sender email from Brevo's Senders & IPs settings.
# If BREVO_FROM_EMAIL is omitted, ADMIN_EMAIL will be used as the sender.
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=verified-sender@yourdomain.com

# ─── Admin notification email ─────────────────────────────────────
# This email receives notifications when users create tickets or add replies
ADMIN_EMAIL=admin@virajprofiles.com
